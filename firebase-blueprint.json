{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "URL to user's profile picture." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the system." },
        "isVip": { "type": "boolean", "description": "Whether the user has VIP status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email", "displayName", "role", "isVip", "createdAt"]
    },
    "CaptureItem": {
      "title": "Capture Item",
      "description": "Stores captured data like notes, documents, audio, etc.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who owns this item." },
        "type": { "type": "string", "enum": ["note", "document", "location", "audio", "video", "schedule"], "description": "Type of captured content." },
        "content": { "type": "object", "description": "The actual content of the capture." },
        "metadata": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the item was captured." }
      },
      "required": ["userId", "type", "content", "metadata", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/captures/{captureId}": {
      "schema": "CaptureItem",
      "description": "Captured items collection."
    }
  }
}
