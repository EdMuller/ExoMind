{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the ExoMind application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile picture URL."
        },
        "cacaVoiceUses": {
          "type": "number",
          "description": "Number of times the user has used the Cacá Voice (max 5)."
        }
      },
      "required": ["uid", "email", "cacaVoiceUses"]
    },
    "Item": {
      "title": "Item",
      "description": "A memory item (text, audio, or video) saved by the user.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The item's unique ID."
        },
        "type": {
          "type": "string",
          "enum": ["text", "audio", "video"],
          "description": "The type of the item."
        },
        "content": {
          "type": "string",
          "description": "The content of the item (text or base64 data)."
        },
        "summary": {
          "type": "string",
          "description": "A summary generated by the AI."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the item was created."
        }
      },
      "required": ["id", "type", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and settings."
    },
    "/users/{userId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/Item" },
      "description": "Memory items belonging to a user."
    }
  }
}
